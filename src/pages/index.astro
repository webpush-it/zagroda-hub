---
import PageShell from "@/components/PageShell.astro";

const { user } = Astro.locals;
const year = new Date().getFullYear();

const primaryBtn = "btn-primary px-6 py-3 text-base";
const secondaryBtn = "btn-secondary px-6 py-3 text-base";
const card = "card-surface";

const clientSteps = [
  "Przeglądaj zagrody edukacyjne w swoim województwie.",
  "Sprawdź dostępność na wybrany termin wycieczki.",
  "Wyślij zapytanie — bez zakładania konta.",
];
---

<PageShell
  title="Zagroda Hub — znajdź zagrodę edukacyjną na wycieczkę"
  description="Przeglądaj zagrody edukacyjne w swoim województwie, sprawdź dostępność na wybrany termin i wyślij zapytanie — bez zakładania konta i bez obdzwaniania kolejnych gospodarstw."
  width="wide"
  brand
>
  <!-- Hero klient-first -->
  <section class="px-2 py-16 text-center sm:py-24">
    <h1 class="text-brand-700 mb-6 text-4xl leading-tight font-extrabold sm:text-5xl lg:text-6xl">
      Znajdź zagrodę edukacyjną na wycieczkę — w swoim województwie.
    </h1>
    <p class="text-ink mx-auto mb-10 max-w-2xl text-lg sm:text-xl">
      Przeglądaj zagrody, sprawdź dostępność na wybrany termin i wyślij zapytanie — bez zakładania konta i bez
      obdzwaniania kolejnych gospodarstw.
    </p>
    <div class="flex flex-col items-center gap-4">
      <a href="/katalog" class:list={primaryBtn}>Znajdź zagrodę</a>
      {
        user && (
          <a href="/dashboard" class:list={secondaryBtn}>
            Przejdź do panelu
          </a>
        )
      }
    </div>
  </section>

  <!-- Jak to działa (klient, kompaktowo) -->
  <section class="py-8">
    <ol class="mx-auto grid max-w-3xl grid-cols-1 gap-4 sm:grid-cols-3">
      {
        clientSteps.map((step, i) => (
          <li class="flex items-start gap-3">
            <span class="bg-brand-600 inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-sm font-semibold text-white">
              {i + 1}
            </span>
            <p class="text-ink-muted text-sm leading-relaxed">{step}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- Skonsolidowana sekcja ownera -->
  <section class="py-12">
    <div class:list={card}>
      <h2 class="text-ink mb-3 text-2xl font-bold sm:text-3xl">Prowadzisz zagrodę?</h2>
      <p class="text-ink-muted mb-6 max-w-2xl text-base leading-relaxed">
        Przyjmuj zapytania nauczycieli online i zarządzaj rezerwacjami z telefonu, jedną ręką, prosto z terenu.
        Akceptujesz lub odrzucasz zgłoszenia jednym tapnięciem, a system pilnuje dziennego limitu miejsc — ten sam dzień
        nie zostanie zarezerwowany ponad limit, nawet jeśli kilku nauczycieli pisze naraz.
      </p>
      {
        user ? (
          <a href="/dashboard" class:list={primaryBtn}>
            Przejdź do panelu
          </a>
        ) : (
          <a href="/auth/signup" class:list={primaryBtn}>
            Załóż konto zagrody
          </a>
        )
      }
    </div>
  </section>

  <!-- Logowanie / rejestracja (tylko gość) -->
  {
    !user && (
      <section class="border-edge border-t py-10 text-center">
        <p class="text-ink-muted mb-4 text-base">Masz już konto zagrody?</p>
        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="/auth/signin" class:list={secondaryBtn}>
            Zaloguj się
          </a>
          <a href="/auth/signup" class:list={primaryBtn}>
            Zarejestruj się
          </a>
        </div>
      </section>
    )
  }

  <!-- Stopka -->
  <footer class="border-edge text-ink-muted border-t py-8 text-center text-sm">
    Zagroda Hub © {year}
  </footer>
</PageShell>
