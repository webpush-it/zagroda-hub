---
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";

const { user } = Astro.locals;
const year = new Date().getFullYear();

const primaryBtn =
  "inline-flex items-center justify-center rounded-lg bg-purple-600 px-6 py-3 text-base font-medium text-white transition-colors hover:bg-purple-500";
const secondaryBtn =
  "inline-flex items-center justify-center rounded-lg border border-white/20 px-6 py-3 text-base font-medium text-white transition-colors hover:bg-white/10";
const card = "rounded-2xl border border-white/10 bg-white/10 p-6 backdrop-blur-xl";

const steps = [
  {
    title: "Znajdź zagrodę",
    body: "Filtruj katalog po województwie, mieście i terminie wycieczki — bez zakładania konta.",
  },
  {
    title: "Wyślij zapytanie",
    body: "Wybierz zagrodę i termin, podaj liczbę osób. Zapytanie trafia prosto do właściciela.",
  },
  {
    title: "Właściciel akceptuje",
    body: "Potwierdzenie przychodzi bez ryzyka podwójnej rezerwacji — system pilnuje limitu miejsc.",
  },
];
---

<Layout
  title="Zagroda Hub — rezerwacje wycieczek do zagród edukacyjnych"
  description="Znajdź zagrodę edukacyjną na wycieczkę albo zarządzaj rezerwacjami swojej zagrody z telefonu — z gwarancją braku podwójnej rezerwacji."
>
  <div class="bg-cosmic min-h-screen p-4 sm:p-8">
    <div class="mx-auto w-full max-w-4xl">
      <Topbar />

      <!-- Hero -->
      <section class="px-2 py-16 text-center sm:py-24">
        <h1
          class="mb-6 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-4xl leading-tight font-bold text-transparent sm:text-5xl lg:text-6xl"
        >
          Zagroda Hub
        </h1>
        <p class="mx-auto mb-4 max-w-2xl text-lg text-white sm:text-xl">
          Telefon dzwoni, gdy karmisz zwierzęta. Nauczyciel obdzwania pół województwa, żeby zarezerwować wycieczkę.
        </p>
        <p class="mx-auto mb-10 max-w-2xl text-base text-blue-100/70 sm:text-lg">
          Zagroda Hub przenosi rezerwacje wycieczek do zagród edukacyjnych do sieci — mobilnie, z telefonu i z
          gwarancją, że ten sam termin nie zostanie zarezerwowany dwa razy.
        </p>
        <div class="flex flex-col gap-4 sm:flex-row sm:justify-center">
          {
            user ? (
              <>
                <a href="/dashboard" class:list={primaryBtn}>
                  Przejdź do panelu
                </a>
                <a href="/dashboard/zapytania" class:list={secondaryBtn}>
                  Zobacz zapytania
                </a>
              </>
            ) : (
              <>
                <a href="/katalog" class:list={primaryBtn}>
                  Przeglądaj zagrody
                </a>
                <a href="/auth/signup" class:list={secondaryBtn}>
                  Dodaj swoją zagrodę
                </a>
              </>
            )
          }
        </div>
      </section>

      <!-- Jak to działa -->
      <section class="py-12">
        <h2 class="mb-8 text-center text-2xl font-bold text-white sm:text-3xl">Jak to działa</h2>
        <ol class="grid grid-cols-1 gap-6 sm:grid-cols-3">
          {
            steps.map((step, i) => (
              <li class:list={card}>
                <span class="mb-4 inline-flex h-9 w-9 items-center justify-center rounded-full bg-purple-600 font-semibold text-white">
                  {i + 1}
                </span>
                <h3 class="mb-2 text-lg font-semibold text-white">{step.title}</h3>
                <p class="text-sm leading-relaxed text-blue-100/70">{step.body}</p>
              </li>
            ))
          }
        </ol>
      </section>

      <!-- Persony -->
      <section class="grid grid-cols-1 gap-6 py-12 md:grid-cols-2">
        <div class:list={card}>
          <h2 class="mb-2 text-xl font-bold text-white">Szukasz zagrody na wycieczkę?</h2>
          <p class="mb-6 text-sm leading-relaxed text-blue-100/70">
            Przeglądaj zagrody edukacyjne w swoim województwie, sprawdź dostępność na wybrany termin i wyślij zapytanie
            — bez zakładania konta i bez obdzwaniania kolejnych gospodarstw.
          </p>
          <a href="/katalog" class:list={primaryBtn}>Przeglądaj zagrody</a>
        </div>
        <div class:list={card}>
          <h2 class="mb-2 text-xl font-bold text-white">Prowadzisz zagrodę?</h2>
          <p class="mb-6 text-sm leading-relaxed text-blue-100/70">
            Zarządzaj zapytaniami z telefonu, jedną ręką, w terenie. Akceptuj lub odrzucaj rezerwacje, a system pilnuje
            limitu miejsc — zero ryzyka podwójnej rezerwacji na ten sam termin.
          </p>
          {
            user ? (
              <a href="/dashboard" class:list={primaryBtn}>
                Przejdź do panelu
              </a>
            ) : (
              <a href="/auth/signup" class:list={primaryBtn}>
                Dodaj swoją zagrodę
              </a>
            )
          }
        </div>
      </section>

      <!-- Stopka -->
      <footer class="border-t border-white/10 py-8 text-center text-sm text-blue-100/50">
        Zagroda Hub © {year}
      </footer>
    </div>
  </div>
</Layout>
