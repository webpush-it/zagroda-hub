---
import PageShell from "@/components/PageShell.astro";
import ZagrodaPlaceholder from "@/components/brand/ZagrodaPlaceholder.astro";

const { user } = Astro.locals;
const year = new Date().getFullYear();

const primaryBtn = "btn-primary px-6 py-3 text-base";
const secondaryBtn = "btn-secondary px-6 py-3 text-base";
const card = "card-surface";

// Dokładnie 3 kroki (research §4). `icon` = klucz mapowany na inline-SVG w renderze
// (dekoracyjny, aria-hidden); ścieżki lucide, bez set:html (guardrail lint).
const clientSteps = [
  { icon: "search", title: "Znajdź zagrodę", body: "Filtruj po województwie, mieście i terminie." },
  { icon: "calendar", title: "Sprawdź termin", body: "Zobacz, które zagrody są wolne w Twojej dacie." },
  { icon: "send", title: "Wyślij zapytanie", body: "Bez konta — gospodarz potwierdza rezerwację." },
];
---

<PageShell
  title="Zagroda Hub — znajdź zagrodę edukacyjną na wycieczkę"
  description="Dla szkół, przedszkoli i rodzin: przeglądaj zagrody edukacyjne w swoim województwie, sprawdź dostępność na wybrany termin i wyślij zapytanie — bez zakładania konta i bez obdzwaniania kolejnych gospodarstw."
  width="wide"
  brand
>
  <!-- Hero klient-first (dwukolumnowy: copy + ilustracja; na mobile ilustracja pod CTA) -->
  <section class="grid grid-cols-1 items-center gap-8 px-2 py-16 sm:py-24 lg:grid-cols-2 lg:gap-12">
    <div class="text-center lg:text-left">
      <h1 class="text-brand-700 mb-6 text-4xl leading-tight font-extrabold sm:text-5xl lg:text-6xl">
        Znajdź zagrodę edukacyjną na wycieczkę — w swoim województwie.
      </h1>
      <p class="text-ink mx-auto mb-6 max-w-2xl text-lg sm:text-xl lg:mx-0">
        Dla szkół i przedszkoli — i dla rodzin szukających pomysłu na dzień z dziećmi. Przeglądaj zagrody, sprawdź
        dostępność na wybrany termin i wyślij zapytanie — bez zakładania konta i bez obdzwaniania kolejnych gospodarstw.
      </p>
      <div class="flex flex-col items-center gap-4 lg:items-start">
        <a href="/katalog" class:list={primaryBtn}>Znajdź zagrodę</a>
        {
          user && (
            <a href="/dashboard" class:list={secondaryBtn}>
              Przejdź do panelu
            </a>
          )
        }
      </div>
      <p class="text-ink-muted mt-4 text-sm">
        Przeglądanie i wysłanie zapytania są bezpłatne. Konto nie jest potrzebne.
      </p>
    </div>
    <div class="border-edge overflow-hidden rounded-2xl border">
      <div class="aspect-video">
        <ZagrodaPlaceholder class="h-full w-full" />
      </div>
    </div>
  </section>

  <!-- Korzyści dla szukającego (tylko funkcje na dziś) -->
  <section class="py-8">
    <h2 class="text-ink mb-8 text-center text-2xl font-bold sm:text-3xl">Dlaczego warto szukać tutaj</h2>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class:list={card}>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-brand-600 mb-3 h-8 w-8"
          aria-hidden="true"
        >
          <rect width="7" height="7" x="3" y="3" rx="1"></rect>
          <rect width="7" height="7" x="14" y="3" rx="1"></rect>
          <rect width="7" height="7" x="14" y="14" rx="1"></rect>
          <rect width="7" height="7" x="3" y="14" rx="1"></rect>
        </svg>
        <h3 class="text-ink mb-2 text-lg font-semibold">Wszystkie zagrody w jednym miejscu</h3>
        <p class="text-ink-muted text-sm leading-relaxed">
          Zamiast obdzwaniać gospodarstwo po gospodarstwie — przeglądasz oferty w swoim województwie na jednej stronie.
        </p>
      </div>
      <div class:list={card}>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-brand-600 mb-3 h-8 w-8"
          aria-hidden="true"
        >
          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
          <circle cx="9" cy="7" r="4"></circle>
          <line x1="17" x2="22" y1="8" y2="13"></line>
          <line x1="22" x2="17" y1="8" y2="13"></line>
        </svg>
        <h3 class="text-ink mb-2 text-lg font-semibold">Bez zakładania konta</h3>
        <p class="text-ink-muted text-sm leading-relaxed">
          Wysyłasz zapytanie od razu. Bez rejestracji i bez kolejnego hasła.
        </p>
      </div>
      <div class:list={card}>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-brand-600 mb-3 h-8 w-8"
          aria-hidden="true"
        >
          <path d="M8 2v4"></path>
          <path d="M16 2v4"></path>
          <rect width="18" height="18" x="3" y="4" rx="2"></rect>
          <path d="M3 10h18"></path>
          <path d="m9 16 2 2 4-4"></path>
        </svg>
        <h3 class="text-ink mb-2 text-lg font-semibold">Sprawdzisz termin od ręki</h3>
        <p class="text-ink-muted text-sm leading-relaxed">
          Wybierasz datę i liczbę osób, a katalog pokazuje, które zagrody są wtedy dostępne.
        </p>
      </div>
      <div class:list={card}>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-brand-600 mb-3 h-8 w-8"
          aria-hidden="true"
        >
          <line x1="22" x2="11" y1="2" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
        <h3 class="text-ink mb-2 text-lg font-semibold">Zapytanie w kilka minut</h3>
        <p class="text-ink-muted text-sm leading-relaxed">Krótki formularz i gotowe — trafia prosto do gospodarza.</p>
      </div>
    </div>
  </section>

  <!-- Pasek zaufania (uczciwe sygnały) -->
  <section class="py-8">
    <h2 class="text-ink mb-8 text-center text-2xl font-bold sm:text-3xl">Na czym możesz polegać</h2>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
      <div class="flex items-start gap-3">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-brand-700 mt-0.5 h-7 w-7 shrink-0"
          aria-hidden="true"
        >
          <path
            d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
          ></path>
          <path d="m9 12 2 2 4-4"></path>
        </svg>
        <p class="text-ink text-sm leading-relaxed">
          <strong class="font-semibold">Gwarancja braku podwójnej rezerwacji</strong> — gdy gospodarz potwierdzi Twój termin,
          jest tylko Twój; system pilnuje dziennego limitu miejsc, nawet gdy kilka grup pyta o ten sam dzień.
        </p>
      </div>
      <div class="flex items-start gap-3">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-brand-700 mt-0.5 h-7 w-7 shrink-0"
          aria-hidden="true"
        >
          <rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
        <p class="text-ink text-sm leading-relaxed">
          Twoje dane kontaktowe trafiają wyłącznie do wybranego gospodarza.
        </p>
      </div>
      <div class="flex items-start gap-3">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-brand-700 mt-0.5 h-7 w-7 shrink-0"
          aria-hidden="true"
        >
          <path
            d="M2.586 17.414A2 2 0 0 0 2 18.828V21a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h1a1 1 0 0 1 1-1v-1a1 1 0 0 1 1-1h.172a2 2 0 0 0 1.414-.586l.814-.814a6.5 6.5 0 1 0-4-4z"
          ></path>
          <circle cx="16.5" cy="7.5" r=".5" fill="currentColor"></circle>
        </svg>
        <p class="text-ink text-sm leading-relaxed">Nie zakładamy konta i nie wysyłamy newsletterów.</p>
      </div>
    </div>
  </section>

  <!-- Jak to działa (3-krokowy wizual) -->
  <section class="py-8">
    <h2 class="text-ink mb-8 text-center text-2xl font-bold sm:text-3xl">Jak to działa</h2>
    <ol class="mx-auto grid max-w-4xl grid-cols-1 gap-4 sm:grid-cols-3">
      {
        clientSteps.map((step, i) => (
          <li class:list={[card, "text-center"]}>
            <div class="mb-3 flex items-center justify-center gap-2">
              <span class="bg-brand-600 inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-sm font-semibold text-white">
                {i + 1}
              </span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand-600 h-8 w-8"
                aria-hidden="true"
              >
                {step.icon === "search" && (
                  <>
                    <circle cx="11" cy="11" r="8" />
                    <path d="m21 21-4.3-4.3" />
                  </>
                )}
                {step.icon === "calendar" && (
                  <>
                    <path d="M8 2v4" />
                    <path d="M16 2v4" />
                    <rect width="18" height="18" x="3" y="4" rx="2" />
                    <path d="M3 10h18" />
                    <path d="m9 16 2 2 4-4" />
                  </>
                )}
                {step.icon === "send" && (
                  <>
                    <line x1="22" x2="11" y1="2" y2="13" />
                    <polygon points="22 2 15 22 11 13 2 9 22 2" />
                  </>
                )}
              </svg>
            </div>
            <h3 class="text-ink mb-1 text-lg font-semibold">{step.title}</h3>
            <p class="text-ink-muted text-sm leading-relaxed">{step.body}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- Domykające, powtórzone CTA -->
  <section class="py-8">
    <div class="bg-accent-100 flex flex-col items-center gap-4 rounded-2xl px-6 py-10 text-center">
      <h2 class="text-accent-700 text-2xl font-bold sm:text-3xl">Gotowy, żeby znaleźć zagrodę?</h2>
      <p class="text-ink max-w-xl text-base">
        Przejrzyj oferty w swoim województwie i wyślij zapytanie — bez zakładania konta.
      </p>
      <a href="/katalog" class:list={primaryBtn}>Znajdź zagrodę</a>
    </div>
  </section>

  <!-- FAQ (natywne <details>/<summary>, bez JS) -->
  <section class="py-8">
    <h2 class="text-ink mb-8 text-center text-2xl font-bold sm:text-3xl">Najczęstsze pytania</h2>
    <div class="mx-auto max-w-3xl space-y-3">
      <details class:list={card}>
        <summary class="tap-target text-ink flex cursor-pointer items-center font-semibold">
          Czy muszę mieć konto, żeby wysłać zapytanie?
        </summary>
        <p class="text-ink-muted mt-2 text-sm leading-relaxed">
          Nie. Wybierasz zagrodę, wypełniasz krótki formularz i wysyłasz — bez rejestracji.
        </p>
      </details>
      <details class:list={card}>
        <summary class="tap-target text-ink flex cursor-pointer items-center font-semibold"> Ile to kosztuje? </summary>
        <p class="text-ink-muted mt-2 text-sm leading-relaxed">
          Przeglądanie katalogu i wysłanie zapytania są bezpłatne. Warunki wizyty ustalasz bezpośrednio z gospodarzem.
        </p>
      </details>
      <details class:list={card}>
        <summary class="tap-target text-ink flex cursor-pointer items-center font-semibold">
          Czy to tylko dla szkół, czy też dla rodzin?
        </summary>
        <p class="text-ink-muted mt-2 text-sm leading-relaxed">
          Dla jednych i drugich — szkoły, przedszkola i rodziny korzystają z tego samego katalogu i formularza
          zapytania.
        </p>
      </details>
      <details class:list={card}>
        <summary class="tap-target text-ink flex cursor-pointer items-center font-semibold">
          Jak sprawdzę, czy zagroda jest wolna w moim terminie?
        </summary>
        <p class="text-ink-muted mt-2 text-sm leading-relaxed">
          Ustawiasz datę i liczbę osób, a katalog pokazuje dostępne zagrody; ostateczne potwierdzenie wysyła gospodarz.
        </p>
      </details>
      <details class:list={card}>
        <summary class="tap-target text-ink flex cursor-pointer items-center font-semibold">
          Co się dzieje po wysłaniu zapytania?
        </summary>
        <p class="text-ink-muted mt-2 text-sm leading-relaxed">
          Trafia prosto do gospodarza, który potwierdza lub odrzuca; dzięki dziennemu limitowi miejsc ten sam dzień nie
          zostanie zarezerwowany ponad limit.
        </p>
      </details>
    </div>
  </section>

  <!-- Skonsolidowana sekcja ownera -->
  <section class="py-12">
    <div class:list={card}>
      <h2 class="text-ink mb-4 text-2xl font-bold sm:text-3xl">Prowadzisz zagrodę?</h2>
      <ul class="mb-6 max-w-2xl space-y-3">
        <li class="flex items-start gap-3">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-ink-muted mt-0.5 h-6 w-6 shrink-0"
            aria-hidden="true"
          >
            <rect width="14" height="20" x="5" y="2" rx="2" ry="2"></rect>
            <path d="M12 18h.01"></path>
          </svg>
          <p class="text-ink-muted text-base leading-relaxed">
            Zarządzaj rezerwacjami z telefonu, jedną ręką, prosto z terenu — akceptuj lub odrzucaj zgłoszenia jednym
            tapnięciem.
          </p>
        </li>
        <li class="flex items-start gap-3">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-ink-muted mt-0.5 h-6 w-6 shrink-0"
            aria-hidden="true"
          >
            <path
              d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
            ></path>
            <path d="m9 12 2 2 4-4"></path>
          </svg>
          <p class="text-ink-muted text-base leading-relaxed">
            System pilnuje dziennego limitu miejsc — ten sam dzień nie zostanie zarezerwowany ponad limit, nawet gdy
            kilku nauczycieli pisze naraz.
          </p>
        </li>
      </ul>
      {
        user ? (
          <a href="/dashboard" class:list={primaryBtn}>
            Przejdź do panelu
          </a>
        ) : (
          <a href="/auth/signup" class:list={primaryBtn}>
            Załóż konto zagrody
          </a>
        )
      }
    </div>
  </section>

  <!-- Logowanie / rejestracja (tylko gość) -->
  {
    !user && (
      <section class="border-edge border-t py-10 text-center">
        <p class="text-ink-muted mb-4 text-base">Masz już konto zagrody?</p>
        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="/auth/signin" class:list={secondaryBtn}>
            Zaloguj się
          </a>
          <a href="/auth/signup" class:list={primaryBtn}>
            Zarejestruj się
          </a>
        </div>
      </section>
    )
  }

  <!-- Stopka -->
  <footer class="border-edge text-ink-muted border-t py-8 text-center text-sm">
    Zagroda Hub © {year}
  </footer>
</PageShell>
