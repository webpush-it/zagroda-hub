---
import PageShell from "@/components/PageShell.astro";
import RequestsList, { type RequestRow } from "@/components/booking/RequestsList";
import { createClient } from "@/lib/supabase";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);

let hasZagroda = false;
let rows: RequestRow[] = [];

if (supabase && user) {
  const { data: zagroda } = await supabase.from("zagrody").select("id").eq("owner_id", user.id).maybeSingle();

  if (zagroda) {
    hasZagroda = true;
    const { data } = await supabase
      .from("booking_requests")
      .select("id, trip_date, participants_count, guest_name, status, created_at, turnusy(label)")
      .eq("zagroda_id", zagroda.id)
      .order("created_at", { ascending: false });

    rows = (data ?? []).map((r) => ({
      id: r.id,
      trip_date: r.trip_date,
      turnus_label: r.turnusy.label,
      participants_count: r.participants_count,
      // Phone entries (S-08) have no guest contact; Phase 3 adds the source
      // badge — until then a placeholder label stands in for the name.
      guest_name: r.guest_name ?? "Wpis telefoniczny",
      status: r.status,
      created_at: r.created_at,
    }));
  }
}
---

<PageShell title="Zapytania o rezerwację">
  <main class="card-surface">
    <h1 class="text-brand-700 mb-6 text-2xl font-bold">Zapytania o rezerwację</h1>
    {
      hasZagroda ? (
        <RequestsList client:load rows={rows} />
      ) : (
        <div class="border-edge bg-surface rounded-xl border p-6 text-center">
          <p class="text-ink font-medium">Brak profilu zagrody</p>
          <p class="text-ink-muted mt-1 text-sm">
            Uzupełnij profil zagrody, aby przyjmować zapytania.{" "}
            <a href="/dashboard" class="text-link hover:text-link-hover hover:underline">
              Przejdź do panelu
            </a>
            .
          </p>
        </div>
      )
    }
  </main>
</PageShell>
