---
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";
import RequestsList, { type RequestRow } from "@/components/booking/RequestsList";
import { createClient } from "@/lib/supabase";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);

let hasZagroda = false;
let rows: RequestRow[] = [];

if (supabase && user) {
  const { data: zagroda } = await supabase.from("zagrody").select("id").eq("owner_id", user.id).maybeSingle();

  if (zagroda) {
    hasZagroda = true;
    const { data } = await supabase
      .from("booking_requests")
      .select("id, trip_date, participants_count, guest_name, status, created_at, turnusy(label)")
      .eq("zagroda_id", zagroda.id)
      .order("created_at", { ascending: false });

    rows = (data ?? []).map((r) => ({
      id: r.id,
      trip_date: r.trip_date,
      turnus_label: r.turnusy.label,
      participants_count: r.participants_count,
      guest_name: r.guest_name,
      status: r.status,
      created_at: r.created_at,
    }));
  }
}
---

<Layout title="Zapytania o rezerwację">
  <div class="bg-cosmic min-h-screen p-4">
    <div class="mx-auto w-full max-w-md">
      <Topbar />
      <main class="rounded-2xl border border-white/10 bg-white/10 p-6 text-white backdrop-blur-xl">
        <h1 class="mb-6 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-2xl font-bold text-transparent">
          Zapytania o rezerwację
        </h1>
        {
          hasZagroda ? (
            <RequestsList client:load rows={rows} />
          ) : (
            <div class="rounded-xl border border-white/10 bg-white/5 p-6 text-center">
              <p class="font-medium text-white">Brak profilu zagrody</p>
              <p class="mt-1 text-sm text-blue-100/60">
                Uzupełnij profil zagrody, aby przyjmować zapytania.{" "}
                <a href="/dashboard" class="text-purple-300 hover:text-purple-100 hover:underline">
                  Przejdź do panelu
                </a>
                .
              </p>
            </div>
          )
        }
      </main>
    </div>
  </div>
</Layout>
