---
import PageShell from "@/components/PageShell.astro";
import RequestDecision from "@/components/booking/RequestDecision";
import { StatusBadge, type RequestStatus } from "@/components/booking/StatusBadge";
import { createClient } from "@/lib/supabase";

const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
const rawId = Astro.params.id ?? "";
const id = UUID_RE.test(rawId) ? rawId : null;

interface RequestDetail {
  id: string;
  trip_date: string;
  turnus_label: string;
  turnus_time: string;
  participants_count: number;
  guest_name: string;
  guest_email: string;
  guest_phone: string;
  status: RequestStatus;
  created_at: string;
}

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);

let request: RequestDetail | null = null;

if (supabase && user && id) {
  // RLS scopes this read to the owner's own requests — a foreign or unknown id
  // returns null and renders the same 404 as a nonexistent request.
  const { data } = await supabase
    .from("booking_requests")
    .select(
      "trip_date, participants_count, guest_name, guest_email, guest_phone, status, created_at, turnusy(label, start_time, end_time)",
    )
    .eq("id", id)
    .maybeSingle();

  if (data) {
    request = {
      id,
      trip_date: data.trip_date,
      turnus_label: data.turnusy.label,
      turnus_time: `${data.turnusy.start_time.slice(0, 5)}–${data.turnusy.end_time.slice(0, 5)}`,
      participants_count: data.participants_count,
      // Phone entries (S-08) have no guest contact; Phase 3 restructures this
      // section — until then placeholders keep the render null-safe.
      guest_name: data.guest_name ?? "Wpis telefoniczny",
      guest_email: data.guest_email ?? "",
      guest_phone: data.guest_phone ?? "",
      status: data.status,
      created_at: data.created_at.slice(0, 10),
    };
  }
}

if (!request) {
  Astro.response.status = 404;
}

const TERMINAL_COPY: Partial<Record<RequestStatus, string>> = {
  accepted: "To zapytanie zostało zaakceptowane.",
  rejected: "To zapytanie zostało odrzucone.",
  cancelled_by_guest: "To zapytanie zostało anulowane przez nauczyciela.",
  withdrawn_by_owner: "Akceptacja tego zapytania została wycofana.",
};
---

<PageShell title={request ? "Szczegóły zapytania" : "Nie znaleziono zapytania"}>
  <main class="card-surface">
    <a href="/dashboard/zapytania" class="text-link hover:text-link-hover tap-target mb-4 text-sm transition-colors">
      ← Wróć do zapytań
    </a>

    {
      request ? (
        <article>
          <h1 class="text-brand-700 text-2xl font-bold">Szczegóły zapytania</h1>
          <p class="text-ink-muted mt-1 text-xs">Wysłano {request.created_at}</p>

          <dl class="mt-6 flex flex-col gap-2">
            <div class="border-edge bg-surface flex items-center justify-between rounded-lg border px-3 py-2 text-sm">
              <dt class="text-ink-muted">Data pobytu</dt>
              <dd class="text-ink font-medium">{request.trip_date}</dd>
            </div>
            <div class="border-edge bg-surface flex items-center justify-between gap-2 rounded-lg border px-3 py-2 text-sm">
              <dt class="text-ink-muted shrink-0">Turnus</dt>
              <dd class="text-ink min-w-0 text-right font-medium break-words">
                {request.turnus_label} <span class="text-ink-muted">({request.turnus_time})</span>
              </dd>
            </div>
            <div class="border-edge bg-surface flex items-center justify-between rounded-lg border px-3 py-2 text-sm">
              <dt class="text-ink-muted">Liczba uczestników</dt>
              <dd class="text-ink font-medium">{request.participants_count}</dd>
            </div>
          </dl>

          <section class="mt-6">
            <h2 class="text-ink mb-2 text-base font-semibold">Kontakt do nauczyciela</h2>
            <dl class="flex flex-col gap-2">
              <div class="border-edge bg-surface flex items-center justify-between gap-2 rounded-lg border px-3 py-2 text-sm">
                <dt class="text-ink-muted shrink-0">Imię i nazwisko</dt>
                <dd class="text-ink min-w-0 text-right font-medium break-words">{request.guest_name}</dd>
              </div>
              <div class="border-edge bg-surface flex items-center justify-between gap-2 rounded-lg border px-3 py-2 text-sm">
                <dt class="text-ink-muted">E-mail</dt>
                <dd class="min-w-0">
                  <a
                    href={`mailto:${request.guest_email}`}
                    class="text-link hover:text-link-hover block truncate font-medium hover:underline"
                  >
                    {request.guest_email}
                  </a>
                </dd>
              </div>
              <div class="border-edge bg-surface flex items-center justify-between rounded-lg border px-3 py-2 text-sm">
                <dt class="text-ink-muted">Telefon</dt>
                <dd>
                  <a
                    href={`tel:${request.guest_phone}`}
                    class="text-link hover:text-link-hover font-medium hover:underline"
                  >
                    {request.guest_phone}
                  </a>
                </dd>
              </div>
            </dl>
          </section>

          <section class="border-edge mt-6 border-t pt-6">
            {request.status === "pending" || request.status === "accepted" ? (
              <RequestDecision client:load id={request.id} initialStatus={request.status} />
            ) : (
              <div class="space-y-3">
                <StatusBadge status={request.status} />
                <p class="border-edge bg-surface text-ink-muted rounded-lg border px-3 py-3 text-sm">
                  {TERMINAL_COPY[request.status]}
                </p>
              </div>
            )}
          </section>
        </article>
      ) : (
        <div class="border-edge bg-surface rounded-xl border p-6 text-center">
          <p class="text-ink font-medium">Nie znaleziono zapytania</p>
          <p class="text-ink-muted mt-1 text-sm">
            Zapytanie nie istnieje lub nie masz do niego dostępu.{" "}
            <a href="/dashboard/zapytania" class="text-link hover:text-link-hover hover:underline">
              Wróć do listy
            </a>
            .
          </p>
        </div>
      )
    }
  </main>
</PageShell>
