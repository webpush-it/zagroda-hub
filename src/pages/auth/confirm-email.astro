---
import Layout from "@/layouts/Layout.astro";

const email = Astro.url.searchParams.get("email") ?? "";
const sent = Astro.url.searchParams.get("sent") === "1";
const error = Astro.url.searchParams.get("error");
---

<Layout title="Sprawdź skrzynkę">
  <div class="bg-meadow flex min-h-screen items-center justify-center p-4">
    <div class="card-surface w-full max-w-sm text-center">
      <div class="mb-4 text-5xl" aria-hidden="true">📧</div>
      <h1 class="text-brand-700 mb-3 text-2xl font-bold">Sprawdź skrzynkę</h1>
      <p class="text-ink mb-6">
        Wysłaliśmy link potwierdzający na Twój adres e-mail. Kliknij go, aby aktywować konto i zalogować się do panelu.
      </p>

      {
        sent && (
          <p class="mb-4 rounded-lg border border-green-300 bg-green-100 px-3 py-2 text-sm text-green-900">
            E-mail został wysłany ponownie. Sprawdź skrzynkę (także folder spam).
          </p>
        )
      }
      {error && <p class="mb-4 rounded-lg border border-red-300 bg-red-100 px-3 py-2 text-sm text-red-900">{error}</p>}

      <form method="post" action="/api/auth/resend" class="mb-6 space-y-3 text-left">
        <label for="email" class="text-ink-muted block text-sm">Nie dotarł? Wyślij ponownie:</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          value={email}
          placeholder="twoj@email.pl"
          class="input-field"
        />
        <button type="submit" class="btn-primary w-full">Wyślij link ponownie</button>
      </form>

      <a href="/auth/signin" class="text-link hover:text-link-hover tap-target text-sm hover:underline">
        Wróć do logowania
      </a>
    </div>
  </div>
</Layout>
