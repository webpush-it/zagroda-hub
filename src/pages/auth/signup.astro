---
import PageShell from "@/components/PageShell.astro";
import SignUpForm from "@/components/auth/SignUpForm";
import OAuthButtons from "@/components/auth/OAuthButtons";

const error = Astro.url.searchParams.get("error");
---

<PageShell title="Zarejestruj się" width="narrow" align="center" showTopbar={false} brand>
  <div class="card-surface">
    <h1 class="text-brand-700 mb-6 text-center text-2xl font-bold">Zarejestruj się</h1>
    <SignUpForm serverError={error} client:load />
    <div class="mt-4">
      <OAuthButtons client:load />
    </div>
    <p class="text-ink-muted mt-4 text-center text-sm">
      Masz już konto? <a href="/auth/signin" class="text-link hover:text-link-hover hover:underline">Zaloguj się</a>
    </p>
  </div>
</PageShell>
