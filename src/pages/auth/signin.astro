---
import PageShell from "@/components/PageShell.astro";
import SignInForm from "@/components/auth/SignInForm";
import OAuthButtons from "@/components/auth/OAuthButtons";

const error = Astro.url.searchParams.get("error");
---

<PageShell title="Zaloguj się" width="narrow" align="center" showTopbar={false}>
  <div class="card-surface">
    <h1 class="text-brand-700 mb-6 text-center text-2xl font-bold">Zaloguj się</h1>
    <SignInForm serverError={error} client:load />
    <div class="mt-4">
      <OAuthButtons client:load />
    </div>
    <p class="text-ink-muted mt-4 text-center text-sm">
      Nie masz konta? <a href="/auth/signup" class="text-link hover:text-link-hover hover:underline">Zarejestruj się</a>
    </p>
  </div>
</PageShell>
