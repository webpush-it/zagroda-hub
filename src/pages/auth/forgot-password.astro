---
import Layout from "@/layouts/Layout.astro";

const email = Astro.url.searchParams.get("email") ?? "";
const sent = Astro.url.searchParams.get("sent") === "1";
const error = Astro.url.searchParams.get("error");
---

<Layout title="Reset hasła">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-sm rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <h1
        class="mb-3 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-center text-2xl font-bold text-transparent"
      >
        Reset hasła
      </h1>

      {
        sent ? (
          <p class="mb-4 rounded-lg border border-green-400/30 bg-green-400/10 px-3 py-2 text-sm text-green-200">
            Jeśli konto z tym adresem istnieje, wysłaliśmy link do resetu hasła. Sprawdź skrzynkę (także folder spam).
          </p>
        ) : (
          <p class="mb-6 text-center text-sm text-blue-100/80">
            Podaj adres e-mail powiązany z kontem. Wyślemy link do ustawienia nowego hasła.
          </p>
        )
      }
      {
        error && (
          <p class="mb-4 rounded-lg border border-red-400/30 bg-red-400/10 px-3 py-2 text-sm text-red-200">{error}</p>
        )
      }

      <form method="post" action="/api/auth/forgot-password" class="space-y-3 text-left">
        <label for="email" class="block text-sm text-blue-100/80">Adres e-mail</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          value={email}
          placeholder="twoj@email.pl"
          class="w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/40 transition-colors focus:ring-2 focus:ring-purple-400 focus:outline-none"
        />
        <button
          type="submit"
          class="w-full rounded-lg bg-purple-600 px-4 py-2 font-medium text-white transition-colors hover:bg-purple-500"
        >
          Wyślij link do resetu
        </button>
      </form>

      <p class="mt-4 text-center text-sm">
        <a href="/auth/signin" class="text-purple-300 hover:underline">Wróć do logowania</a>
      </p>
    </div>
  </div>
</Layout>
