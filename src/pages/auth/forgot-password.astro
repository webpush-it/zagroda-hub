---
import Layout from "@/layouts/Layout.astro";

const email = Astro.url.searchParams.get("email") ?? "";
const sent = Astro.url.searchParams.get("sent") === "1";
const error = Astro.url.searchParams.get("error");
---

<Layout title="Reset hasła">
  <div class="bg-meadow flex min-h-screen items-center justify-center p-4">
    <div class="card-surface w-full max-w-sm">
      <h1 class="text-brand-700 mb-3 text-center text-2xl font-bold">Reset hasła</h1>

      {
        sent ? (
          <p class="mb-4 rounded-lg border border-green-300 bg-green-100 px-3 py-2 text-sm text-green-900">
            Jeśli konto z tym adresem istnieje, wysłaliśmy link do resetu hasła. Sprawdź skrzynkę (także folder spam).
          </p>
        ) : (
          <p class="text-ink-muted mb-6 text-center text-sm">
            Podaj adres e-mail powiązany z kontem. Wyślemy link do ustawienia nowego hasła.
          </p>
        )
      }
      {error && <p class="mb-4 rounded-lg border border-red-300 bg-red-100 px-3 py-2 text-sm text-red-900">{error}</p>}

      <form method="post" action="/api/auth/forgot-password" class="space-y-3 text-left">
        <label for="email" class="text-ink-muted block text-sm">Adres e-mail</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          value={email}
          placeholder="twoj@email.pl"
          class="input-field"
        />
        <button type="submit" class="btn-primary w-full">Wyślij link do resetu</button>
      </form>

      <p class="mt-4 text-center text-sm">
        <a href="/auth/signin" class="text-link hover:text-link-hover tap-target hover:underline">Wróć do logowania</a>
      </p>
    </div>
  </div>
</Layout>
