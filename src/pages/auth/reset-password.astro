---
import PageShell from "@/components/PageShell.astro";
import ResetPasswordForm from "@/components/auth/ResetPasswordForm";

// The set-new-password form is only reachable with an active session — the
// recovery link (confirm.ts verifyOtp) establishes one. No session means the
// link expired, was already used, or the page was opened cold: send the user
// back to request a fresh link rather than showing a form that can't submit.
if (!Astro.locals.user) {
  return Astro.redirect(
    `/auth/forgot-password?error=${encodeURIComponent("Link wygasł lub został już użyty. Poproś o nowy link do resetu hasła.")}`,
  );
}

const error = Astro.url.searchParams.get("error");
---

<PageShell title="Ustaw nowe hasło" width="narrow" align="center" showTopbar={false}>
  <div class="card-surface">
    <h1 class="text-brand-700 mb-6 text-center text-2xl font-bold">Ustaw nowe hasło</h1>
    <ResetPasswordForm serverError={error} client:load />
  </div>
</PageShell>
