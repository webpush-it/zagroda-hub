---
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";
import CancelRequest from "@/components/booking/CancelRequest";

export const prerender = false;

// GET is side-effect-free: we only read the token from the query and validate
// its shape. No DB read or mutation here — a refresh or link-prefetch must not
// cancel anything. The actual cancel is an explicit POST from the island.
const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
const rawToken = Astro.url.searchParams.get("token") ?? "";
const token = UUID_RE.test(rawToken) ? rawToken : null;
---

<Layout title="Anuluj zapytanie">
  <div class="bg-cosmic min-h-screen p-4">
    <div class="mx-auto w-full max-w-md">
      <Topbar />
      <main class="rounded-2xl border border-white/10 bg-white/10 p-6 text-white backdrop-blur-xl">
        {
          token ? (
            <div>
              <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-2xl font-bold text-transparent">
                Anulowanie zapytania
              </h1>
              <p class="mt-4 text-sm text-blue-100/80">Czy na pewno chcesz anulować to zapytanie?</p>
              <div class="mt-6">
                <CancelRequest client:load token={token} />
              </div>
            </div>
          ) : (
            <div class="rounded-xl border border-white/10 bg-white/5 p-6 text-center">
              <p class="font-medium text-white">Nieprawidłowy link</p>
              <p class="mt-1 text-sm text-blue-100/60">
                Link do anulowania jest nieprawidłowy lub niekompletny.{" "}
                <a href="/katalog" class="text-purple-300 hover:text-purple-100 hover:underline">
                  Przejdź do katalogu
                </a>
                .
              </p>
            </div>
          )
        }
      </main>
    </div>
  </div>
</Layout>
