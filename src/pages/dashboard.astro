---
import PageShell from "@/components/PageShell.astro";
import ZagrodaProfileForm, { type ZagrodaInitialData } from "@/components/zagroda/ZagrodaProfileForm";
import { createClient } from "@/lib/supabase";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);

let initialData: ZagrodaInitialData | null = null;
let photoUrl: string | null = null;

if (supabase && user) {
  const { data: zagroda } = await supabase
    .from("zagrody")
    .select(
      "name, description, voivodeship, city, daily_limit, is_published, photo_path, latitude, longitude, location_source, turnusy(id, label, start_time, end_time)",
    )
    .eq("owner_id", user.id)
    .maybeSingle();

  if (zagroda) {
    // The manual pin is only meaningful when location_source='manual'; for 'auto'
    // rows the stored coords are name-derived and must NOT seed the form as a pin
    // (that would flip the row to manual on the next save).
    const isManual = zagroda.location_source === "manual";
    // Name-derived coords power the "Użyj lokalizacji miasta" anchor. Computed
    // server-side from the current city/voivodeship, independent of the pin.
    let fallback: { lat: number; lng: number } | null = null;
    if (zagroda.voivodeship && zagroda.city) {
      const { data: coords } = await supabase.rpc("locality_coords", {
        p_voivodeship: zagroda.voivodeship,
        p_city: zagroda.city,
      });
      const hit = coords?.[0];
      if (hit) fallback = { lat: hit.latitude, lng: hit.longitude };
    }
    initialData = {
      name: zagroda.name,
      description: zagroda.description ?? "",
      voivodeship: zagroda.voivodeship,
      city: zagroda.city ?? "",
      daily_limit: zagroda.daily_limit,
      is_published: zagroda.is_published,
      latitude: isManual ? zagroda.latitude : null,
      longitude: isManual ? zagroda.longitude : null,
      fallback,
      turnusy: zagroda.turnusy
        .map((t) => ({
          id: t.id,
          label: t.label,
          start_time: t.start_time.slice(0, 5),
          end_time: t.end_time.slice(0, 5),
        }))
        .sort((a, b) => a.start_time.localeCompare(b.start_time)),
    };
    if (zagroda.photo_path) {
      photoUrl = supabase.storage.from("zagroda-photos").getPublicUrl(zagroda.photo_path).data.publicUrl;
    }
  }
}
---

<PageShell title="Panel zagrody">
  <main class="card-surface">
    <h1 class="text-brand-700 mb-6 text-2xl font-bold">Panel zagrody</h1>
    <a
      href="/dashboard/zapytania"
      class="border-edge bg-surface text-ink hover:bg-brand-50 mb-6 flex items-center justify-between rounded-xl border px-4 py-3 text-sm font-medium transition-colors"
    >
      Zapytania o rezerwację
      <span class="text-link" aria-hidden="true">→</span>
    </a>
    <ZagrodaProfileForm client:load initialData={initialData} photoUrl={photoUrl} />
  </main>
</PageShell>
