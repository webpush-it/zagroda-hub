---
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";
import { createClient } from "@/lib/supabase";

const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
const rawId = Astro.params.id ?? "";
const id = UUID_RE.test(rawId) ? rawId : null;

interface ZagrodaProfile {
  name: string;
  description: string;
  lokalizacja: string;
  dailyLimit: number;
  photoUrl: string | null;
  turnusy: { id: string; label: string; time: string }[];
}

const supabase = createClient(Astro.request.headers, Astro.cookies);

let profile: ZagrodaProfile | null = null;

if (supabase && id) {
  // Explicit publish predicate — authenticated-owner RLS would otherwise let
  // an owner open their own draft; drafts must 404 here like for anon.
  const { data: zagroda } = await supabase
    .from("zagrody")
    .select("name, description, voivodeship, city, daily_limit, photo_path, turnusy(id, label, start_time, end_time)")
    .eq("id", id)
    .eq("is_published", true)
    .maybeSingle();

  if (zagroda) {
    // city/description/photo_path can be null on a published row edited after
    // publication (the publish gate checks completeness only at publish time).
    profile = {
      name: zagroda.name,
      description: zagroda.description ?? "",
      lokalizacja: [zagroda.city ?? "", zagroda.voivodeship ?? ""].filter(Boolean).join(", "),
      dailyLimit: zagroda.daily_limit,
      photoUrl: zagroda.photo_path
        ? supabase.storage.from("zagroda-photos").getPublicUrl(zagroda.photo_path).data.publicUrl
        : null,
      turnusy: zagroda.turnusy
        .map((t) => ({
          id: t.id,
          label: t.label,
          time: `${t.start_time.slice(0, 5)}–${t.end_time.slice(0, 5)}`,
        }))
        .sort((a, b) => a.time.localeCompare(b.time)),
    };
  }
}

if (!profile) {
  Astro.response.status = 404;
}
---

<Layout title={profile ? profile.name : "Nie znaleziono zagrody"}>
  <div class="bg-cosmic min-h-screen p-4">
    <div class="mx-auto w-full max-w-md">
      <Topbar />
      <main class="rounded-2xl border border-white/10 bg-white/10 p-6 text-white backdrop-blur-xl">
        <a href="/katalog" class="mb-4 inline-block text-sm text-purple-300 transition-colors hover:text-purple-100">
          ← Wróć do katalogu
        </a>

        {
          profile ? (
            <article>
              {profile.photoUrl ? (
                <img src={profile.photoUrl} alt="" class="mb-4 aspect-video w-full rounded-xl object-cover" />
              ) : (
                <div
                  class="mb-4 flex aspect-video w-full items-center justify-center rounded-xl bg-white/10 text-5xl"
                  aria-hidden="true"
                >
                  🏡
                </div>
              )}

              <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-2xl font-bold text-transparent">
                {profile.name}
              </h1>
              {profile.lokalizacja && <p class="mt-1 text-sm text-blue-100/70">{profile.lokalizacja}</p>}

              {profile.description && (
                <p class="mt-4 text-sm whitespace-pre-line text-blue-100/80">{profile.description}</p>
              )}

              <p class="mt-4 text-sm text-blue-100/70">
                Dzienny limit osób: <span class="font-semibold text-white">{profile.dailyLimit}</span>
              </p>

              {profile.turnusy.length > 0 && (
                <section class="mt-6">
                  <h2 class="mb-2 text-base font-semibold text-white">Turnusy</h2>
                  <ul class="flex flex-col gap-2">
                    {profile.turnusy.map((t) => (
                      <li class="flex items-center justify-between rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm">
                        <span class="text-white">{t.label}</span>
                        <span class="text-blue-100/70">{t.time}</span>
                      </li>
                    ))}
                  </ul>
                </section>
              )}
            </article>
          ) : (
            <div class="rounded-xl border border-white/10 bg-white/5 p-6 text-center">
              <p class="font-medium text-white">Nie znaleziono zagrody</p>
              <p class="mt-1 text-sm text-blue-100/60">
                Zagroda nie istnieje lub nie jest opublikowana.{" "}
                <a href="/katalog" class="text-purple-300 hover:text-purple-100 hover:underline">
                  Przejdź do katalogu
                </a>
                .
              </p>
            </div>
          )
        }
      </main>
    </div>
  </div>
</Layout>
