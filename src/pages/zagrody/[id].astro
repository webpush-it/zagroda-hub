---
import PageShell from "@/components/PageShell.astro";
import BookingRequestForm from "@/components/booking/BookingRequestForm";
import ZagrodaMapEmbed from "@/components/zagroda/ZagrodaMapEmbed";
import ZagrodaPlaceholder from "@/components/brand/ZagrodaPlaceholder.astro";
import { createClient } from "@/lib/supabase";
import {
  OFERTA_ADRESAT_LABELS,
  OFERTA_TEMAT_LABELS,
  formatOfferPrice,
  type OfertaAdresat,
  type OfertaTemat,
} from "@/lib/offer";

const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
const rawId = Astro.params.id ?? "";
const id = UUID_RE.test(rawId) ? rawId : null;

interface ZagrodaProfile {
  id: string;
  name: string;
  description: string;
  lokalizacja: string;
  // Only precise coords get a marker — matches the catalog's location_precise gating.
  // Imprecise auto rows (unresolved city → voivodeship centroid) show no map.
  mapCoords: { lat: number; lng: number } | null;
  dailyLimit: number;
  photoUrl: string | null;
  turnusy: { id: string; label: string; time: string }[];
  offers: {
    id: string;
    nazwa: string;
    opis: string | null;
    czas_trwania: string | null;
    temat: OfertaTemat[];
    adresaci: OfertaAdresat[];
    price: string;
  }[];
}

const supabase = createClient(Astro.request.headers, Astro.cookies);

let profile: ZagrodaProfile | null = null;

if (supabase && id) {
  // Explicit publish predicate — authenticated-owner RLS would otherwise let
  // an owner open their own draft; drafts must 404 here like for anon.
  const { data: zagroda } = await supabase
    .from("zagrody")
    .select(
      "name, description, voivodeship, city, daily_limit, latitude, longitude, location_precise, photo_path, turnusy(id, label, start_time, end_time), oferty(id, nazwa, opis, czas_trwania, temat, adresaci, amount_grosze, price_unit, sort_order)",
    )
    .eq("id", id)
    .eq("is_published", true)
    .maybeSingle();

  if (zagroda) {
    // city/description/photo_path can be null on a published row edited after
    // publication (the publish gate checks completeness only at publish time).
    profile = {
      id,
      name: zagroda.name,
      description: zagroda.description ?? "",
      lokalizacja: [zagroda.city ?? "", zagroda.voivodeship ?? ""].filter(Boolean).join(", "),
      mapCoords:
        zagroda.location_precise && zagroda.latitude != null && zagroda.longitude != null
          ? { lat: zagroda.latitude, lng: zagroda.longitude }
          : null,
      dailyLimit: zagroda.daily_limit,
      photoUrl: zagroda.photo_path
        ? supabase.storage.from("zagroda-photos").getPublicUrl(zagroda.photo_path).data.publicUrl
        : null,
      turnusy: zagroda.turnusy
        .map((t) => ({
          id: t.id,
          label: t.label,
          time: `${t.start_time.slice(0, 5)}–${t.end_time.slice(0, 5)}`,
        }))
        .sort((a, b) => a.time.localeCompare(b.time)),
      // Public-read RLS returns only active offers on a published zagroda;
      // owner sort_order drives display order.
      offers: zagroda.oferty
        .slice()
        .sort((a, b) => a.sort_order - b.sort_order)
        .map((o) => ({
          id: o.id,
          nazwa: o.nazwa,
          opis: o.opis,
          czas_trwania: o.czas_trwania,
          temat: o.temat,
          adresaci: o.adresaci,
          price: formatOfferPrice(o.amount_grosze, o.price_unit),
        })),
    };
  }
}

if (!profile) {
  Astro.response.status = 404;
}
---

<PageShell title={profile ? profile.name : "Nie znaleziono zagrody"}>
  <main class="card-surface">
    <a href="/katalog" class="text-link hover:text-link-hover tap-target mb-4 text-sm transition-colors">
      ← Wróć do katalogu
    </a>

    {
      profile ? (
        <article>
          {profile.photoUrl ? (
            <img src={profile.photoUrl} alt={profile.name} class="mb-4 aspect-video w-full rounded-xl object-cover" />
          ) : (
            <div class="mb-4 aspect-video w-full overflow-hidden rounded-xl">
              <ZagrodaPlaceholder />
            </div>
          )}

          <h1 class="text-brand-700 text-2xl font-bold break-words">{profile.name}</h1>
          {profile.lokalizacja && <p class="text-ink-muted mt-1 text-sm">{profile.lokalizacja}</p>}

          {profile.mapCoords && (
            <div class="mt-4">
              {/* Lazy-hydrated on scroll; the wrapper is server-safe and defers Leaflet to the client. */}
              <ZagrodaMapEmbed client:visible latitude={profile.mapCoords.lat} longitude={profile.mapCoords.lng} />
            </div>
          )}

          {profile.description && <p class="text-ink mt-4 text-sm whitespace-pre-line">{profile.description}</p>}

          <p class="text-ink-muted mt-4 text-sm">
            Dzienny limit osób: <span class="text-ink font-semibold">{profile.dailyLimit}</span>
          </p>

          {profile.turnusy.length > 0 && (
            <section class="mt-6">
              <h2 class="text-ink mb-2 text-base font-semibold">Turnusy</h2>
              <ul class="flex flex-col gap-2">
                {profile.turnusy.map((t) => (
                  <li class="border-edge bg-surface flex items-center justify-between gap-2 rounded-lg border px-3 py-2 text-sm">
                    <span class="text-ink min-w-0 truncate">{t.label}</span>
                    <span class="text-ink-muted shrink-0">{t.time}</span>
                  </li>
                ))}
              </ul>
            </section>
          )}

          {profile.offers.length > 0 && (
            <section class="mt-6">
              <h2 class="text-ink mb-2 text-base font-semibold">Oferty</h2>
              <ul class="flex flex-col gap-3">
                {profile.offers.map((o) => (
                  <li class="border-edge bg-surface rounded-lg border p-3">
                    <div class="flex items-start justify-between gap-2">
                      <p class="text-ink min-w-0 font-medium break-words">{o.nazwa}</p>
                      <span class="text-brand-700 shrink-0 text-sm font-semibold">{o.price}</span>
                    </div>
                    {o.czas_trwania && <p class="text-ink-muted mt-1 text-sm">{o.czas_trwania}</p>}
                    {o.opis && <p class="text-ink mt-1 text-sm whitespace-pre-line">{o.opis}</p>}
                    <div class="mt-2 flex flex-wrap gap-1">
                      {o.temat.map((t) => (
                        <span class="border-edge text-ink-muted rounded-full border bg-white px-2 py-0.5 text-xs">
                          {OFERTA_TEMAT_LABELS[t]}
                        </span>
                      ))}
                      {o.adresaci.map((a) => (
                        <span class="border-brand-200 bg-brand-50 text-brand-700 rounded-full border px-2 py-0.5 text-xs">
                          {OFERTA_ADRESAT_LABELS[a]}
                        </span>
                      ))}
                    </div>
                  </li>
                ))}
              </ul>
            </section>
          )}

          <section class="border-edge mt-6 border-t pt-6">
            <BookingRequestForm
              client:load
              zagrodaId={profile.id}
              turnusy={profile.turnusy}
              dailyLimit={profile.dailyLimit}
            />
          </section>
        </article>
      ) : (
        <div class="border-edge bg-surface rounded-xl border p-6 text-center">
          <p class="text-ink font-medium">Nie znaleziono zagrody</p>
          <p class="text-ink-muted mt-1 text-sm">
            Zagroda nie istnieje lub nie jest opublikowana.{" "}
            <a href="/katalog" class="text-link hover:text-link-hover hover:underline">
              Przejdź do katalogu
            </a>
            .
          </p>
        </div>
      )
    }
  </main>
</PageShell>
