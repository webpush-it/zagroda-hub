---
type Variant = "info" | "warning" | "error";

interface Props {
  variant?: Variant;
}

const { variant = "info" } = Astro.props;
---

<div class:list={["banner", `banner--${variant}`]} role={variant === "error" ? "alert" : "status"}>
  <slot />
</div>

<style>
  .banner {
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    text-align: center;
    border-bottom: 1px solid;
  }
  .banner :global(a) {
    color: inherit;
    text-decoration: underline;
    font-weight: 600;
  }
  .banner--info {
    background: #e2edd8;
    color: #29511c;
    border-color: #3f7d2c;
  }
  .banner--warning {
    background: #f6e8d5;
    color: #8a4407;
    border-color: #d98e2b;
  }
  .banner--error {
    background: #fee2e2;
    color: #7f1d1d;
    border-color: #dc2626;
  }
</style>
