---
import Logo from "@/components/brand/Logo.astro";
import TopbarMobileMenu, { type NavLink } from "@/components/TopbarMobileMenu";
import AccountMenu from "@/components/AccountMenu";

const { user } = Astro.locals;

// Tap-target ≥44px na mobile (guardrail jednoręczności).
const navLink = "tap-target text-link transition-colors hover:text-link-hover hover:underline";
// CTA klient-first („Znajdź zagrodę") — wyróżniony przycisk marki, sizing dopasowany do niskiego paska.
const navCta = "btn-primary px-4 text-sm";

// Payload linków budowany raz — współdzielony przez wariant desktop (inline) i mobile (drawer),
// by stan gość/zalogowany nie rozjechał się między powierzchniami.
const links: NavLink[] = user
  ? [
      { href: "/katalog", label: "Katalog" },
      { href: "/dashboard", label: "Panel" },
      { href: "/dashboard/zapytania", label: "Zapytania" },
    ]
  : [
      { href: "/katalog", label: "Znajdź zagrodę", cta: true },
      { href: "/auth/signin", label: "Zaloguj się" },
      { href: "/auth/signup", label: "Zarejestruj się" },
    ];
const signOutAction = user ? "/api/auth/signout" : undefined;
---

<div
  class="border-edge text-ink-muted mb-4 flex min-w-0 items-center justify-between gap-3 rounded-xl border bg-white px-4 py-2 text-sm"
>
  <a href="/" class="tap-target" aria-label="Zagroda Hub — strona główna">
    <Logo variant="full" size={28} />
  </a>

  <div class="hidden min-w-0 items-center gap-4 sm:flex">
    {
      links.map((link) => (
        <a href={link.href} class:list={link.cta ? navCta : navLink}>
          {link.label}
        </a>
      ))
    }
    {signOutAction && <AccountMenu client:idle userEmail={user?.email} signOutAction={signOutAction} />}
  </div>

  <TopbarMobileMenu client:idle links={links} signOutAction={signOutAction} userEmail={user?.email} />
</div>
