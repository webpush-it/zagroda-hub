---
import ZagrodaPlaceholder from "@/components/brand/ZagrodaPlaceholder.astro";

interface Props {
  id: string;
  name: string;
  description: string;
  city: string;
  voivodeship: string;
  photoUrl: string | null;
  available: boolean | null;
}

// `name` and `location` are renamed locally — the template's type analysis
// would otherwise resolve them to the (deprecated/always-truthy) DOM globals.
const { id, name: zagrodaName, description, city, voivodeship, photoUrl, available } = Astro.props;

// `false` mutes the card and removes the link; `null` (no date filter) and
// `true` both render a clickable card.
const unavailable = available === false;
const lokalizacja = [city, voivodeship].filter(Boolean).join(", ");
const excerpt = description.length > 120 ? `${description.slice(0, 120).trimEnd()}…` : description;
---

<article
  class:list={[
    "border-edge relative flex gap-3 rounded-xl border bg-white p-3 shadow-sm transition-colors",
    unavailable ? "opacity-60" : "hover:border-brand-200",
  ]}
>
  {
    photoUrl ? (
      <img src={photoUrl} alt="" class="h-20 w-20 shrink-0 rounded-lg object-cover" loading="lazy" />
    ) : (
      <div class="h-20 w-20 shrink-0 overflow-hidden rounded-lg">
        <ZagrodaPlaceholder />
      </div>
    )
  }
  <div class="min-w-0">
    <h2 class="text-ink truncate text-base font-semibold">
      {
        unavailable ? (
          zagrodaName
        ) : (
          <a href={`/zagrody/${id}`} class="after:absolute after:inset-0 hover:underline">
            {zagrodaName}
          </a>
        )
      }
    </h2>
    {lokalizacja && <p class="text-ink-muted truncate text-sm">{lokalizacja}</p>}
    {excerpt && <p class="text-ink-muted mt-1 line-clamp-2 text-sm">{excerpt}</p>}
    {
      unavailable && (
        <span class="mt-2 inline-block rounded-full border border-red-300 bg-red-100 px-2 py-0.5 text-xs font-medium text-red-900">
          Brak wolnych miejsc
        </span>
      )
    }
  </div>
</article>
