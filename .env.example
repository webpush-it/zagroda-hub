# Local dev only. Copy to .env for `npm run dev`.
# Production (Cloudflare Workers) does NOT read this file — secrets are set with:
#   npx wrangler secret put SUPABASE_URL
#   npx wrangler secret put SUPABASE_KEY
SUPABASE_URL=###
SUPABASE_KEY=###
# Service-role key for internal infrastructure (email outbox). Local value:
# `supabase status` → "service_role key". Optional — outbox degrades to no-op.
SUPABASE_SERVICE_ROLE_KEY=
# Transactional email via Brevo. All optional — when unset the email channel
# degrades to a logged no-op. EMAIL_FROM must be the Brevo-verified single
# sender address; EMAIL_FROM_NAME defaults to "Zagroda Hub".
BREVO_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=
# OAuth provider credentials (FR-017). Consumed by the Supabase CLI via env()
# substitution in config.toml for LOCAL dev only — the Astro worker does not
# read these (redirectTo is derived from the request origin). Production
# credentials live in the hosted Supabase dashboard, not here. Create the OAuth
# apps in the Google Cloud / Meta consoles; authorized redirect URI (local) is
# http://127.0.0.1:54321/auth/v1/callback.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
SUPABASE_AUTH_EXTERNAL_FACEBOOK_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_FACEBOOK_SECRET=
